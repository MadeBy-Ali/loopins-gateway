# Loopins Gateway - Environment Variables
# Copy to .env and fill in for your VPS

# Port the gateway listens on (use 80 on VPS, 8000 locally)
GATEWAY_PORT=8000

# Internal service URLs (on VPS, use docker network names or localhost)
CORE_SERVICE_URL=http://localhost:8080
FULFILLMENT_SERVICE_URL=http://localhost:8081

# CORS - your frontend domain
ALLOWED_ORIGINS=http://localhost:3000
